{
  "$meta": {
    "brand": "Jaé",
    "source": "jae.com.br (identidade visual oficial)",
    "description": "Design tokens da Jaé para reuso no redesign do app"
  },
  "color": {
    "primitive": {
      "green": {
        "50":  "#eaf6ed",
        "100": "#cfead6",
        "300": "#9bd4a8",
        "500": "#65bc7b",
        "700": "#4a9a5e",
        "900": "#2f6b3d"
      },
      "amber": {
        "main":   "#ffc107",
        "deep":   "#ffaf00",
        "darker": "#f5ac13"
      },
      "teal":  "#2ed5c4",
      "neutral": {
        "black":   "#000000",
        "ink900":  "#232323",
        "ink800":  "#2c2d33",
        "ink700":  "#2d2d2d",
        "ink600":  "#303030",
        "gray500": "#404040",
        "gray300": "#e2e2e2",
        "white":   "#ffffff"
      }
    },
    "semantic": {
      "primary":       "#65bc7b",
      "primaryHover":  "#4a9a5e",
      "secondary":     "#ffc107",
      "accent":        "#2ed5c4",
      "bg":            "#ffffff",
      "bgInverse":     "#000000",
      "surface":       "#ffffff",
      "surfaceMuted":  "#eaf6ed",
      "text":          "#232323",
      "textMuted":     "#404040",
      "textInverse":   "#ffffff",
      "border":        "#e2e2e2",
      "success":       "#65bc7b",
      "warning":       "#ffc107"
    }
  },
  "typography": {
    "fontFamily": {
      "display": "Comfortaa, Montserrat, sans-serif",
      "body":    "Montserrat, Roboto, -apple-system, sans-serif"
    },
    "fontWeight": { "regular": 400, "medium": 500, "bold": 700, "extra": 800 },
    "fontSize": {
      "xs": "12px", "sm": "14px", "base": "16px", "md": "20px",
      "lg": "25px", "xl": "31px", "2xl": "39px", "3xl": "49px"
    },
    "lineHeight": { "tight": 1.15, "normal": 1.5, "relaxed": 1.7 }
  },
  "spacing": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "6": "24px", "8": "32px", "12": "48px", "16": "64px", "24": "96px"
  },
  "radius": {
    "sm": "8px", "md": "16px", "lg": "24px", "pill": "999px"
  },
  "shadow": {
    "sm": "0 1px 3px rgba(0,0,0,.08)",
    "md": "0 6px 20px rgba(0,0,0,.10)",
    "lg": "0 16px 40px rgba(0,0,0,.14)"
  }
}
